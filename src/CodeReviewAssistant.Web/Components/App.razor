<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["CodeReviewAssistant.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/svg+xml" href="robot-logo.svg" />
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script>
        window.craClipboard = async (text) => {
            await navigator.clipboard.writeText(text);
        };
        window.craDownload = (filename, content) => {
            const blob = new Blob([content], { type: 'text/markdown; charset=utf-8' });
            const url  = URL.createObjectURL(blob);
            const a    = Object.assign(document.createElement('a'), { href: url, download: filename });
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        };
        window.craScrollToTop = () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        };
        window.craScrollToFile = (id) => {
            const el     = document.getElementById(id);
            const sticky = document.querySelector('.rcb-sticky-wrapper');
            if (!el) return;
            const offset = sticky ? sticky.getBoundingClientRect().height + 16 : 16;
            const y      = el.getBoundingClientRect().top + window.scrollY - offset;
            window.scrollTo({ top: y, behavior: 'smooth' });
        };
        window.craRegisterEscHandler = (dotnetRef) => {
            window._craEscDotnet = dotnetRef;
            if (!window._craEscBound) {
                window._craEscBound = true;
                document.addEventListener('keydown', window._craEscListener = (e) => {
                    if (e.key === 'Escape' && window._craEscDotnet) {
                        window._craEscDotnet.invokeMethodAsync('CancelReview');
                    }
                });
            }
        };
        window.craUnregisterEscHandler = () => {
            window._craEscDotnet = null;
            if (window._craEscBound) {
                document.removeEventListener('keydown', window._craEscListener);
                window._craEscBound = false;
                window._craEscListener = null;
            }
        };
    </script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
