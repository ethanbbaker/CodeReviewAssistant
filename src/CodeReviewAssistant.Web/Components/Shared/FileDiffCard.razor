@using System.Text

<div class="diff-card" id="file-@Index">

    <!-- File header -->
    <div class="diff-card-header">
        <div class="diff-file-info">
            <span class="@GetStatusBadgeClass() status-badge-sm">@Diff.Status.ToString().ToLowerInvariant()</span>
            @if (Diff.PreviousFileName is not null)
            {
                <span class="diff-old-name font-mono" title="@Diff.PreviousFileName">@Diff.PreviousFileName</span>
                <svg style="width:12px;height:12px;color:#8b949e;flex-shrink:0;" viewBox="0 0 16 16" fill="currentColor">
                    <path fill-rule="evenodd" d="M1 8a.5.5 0 01.5-.5h11.793l-3.147-3.146a.5.5 0 01.708-.708l4 4a.5.5 0 010 .708l-4 4a.5.5 0 01-.708-.708L13.293 8.5H1.5A.5.5 0 011 8z"/>
                </svg>
            }
            <span class="diff-file-name font-mono" title="@Diff.FileName">@Diff.FileName</span>
        </div>

        <div class="diff-file-stats">
            @if (!Diff.IsBinary)
            {
                <span class="stat-add">+@Diff.Additions</span>
                <span class="stat-del">-@Diff.Deletions</span>
            }
            @if (Diff.IsTruncated)
            {
                <span class="badge-truncated" title="Diff truncated at @DiffParser.MaxPatchLines lines">truncated</span>
            }
        </div>
    </div>

    <!-- Diff body -->
    @if (Diff.IsBinary)
    {
        <div class="diff-binary-notice">
            <svg style="width:16px;height:16px;flex-shrink:0;" viewBox="0 0 16 16" fill="currentColor">
                <path d="M9.293 0H4a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V4.707A1 1 0 0013.707 4L10 .293A1 1 0 009.293 0zM9.5 3.5v-2l3 3h-2a1 1 0 01-1-1zM6.5 7.5a1 1 0 000 2h.5v1a.5.5 0 001 0v-1h.5a1 1 0 000-2H6.5z"/>
            </svg>
            Binary file — diff not available
        </div>
    }
    else if (string.IsNullOrEmpty(Diff.Patch))
    {
        <div class="diff-empty-notice">No diff content available</div>
    }
    else
    {
        <div class="diff-lines">
            @foreach (var line in _lines)
            {
                <div class="@line.CssClass">
                    <span class="diff-gutter" aria-hidden="true">@line.Prefix</span>
                    <span class="diff-code">@line.Content</span>
                </div>
            }
            @if (Diff.IsTruncated)
            {
                <div class="diff-truncation-notice">
                    ⋯ diff truncated after @DiffParser.MaxPatchLines lines
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public FileDiff Diff  { get; set; } = null!;
    [Parameter]                 public int      Index { get; set; }

    private List<DiffLineVm> _lines = new();

    protected override void OnParametersSet() => _lines = ParsePatch(Diff.Patch);

    // ----------------------------------------------------------------
    // Patch parsing
    // ----------------------------------------------------------------

    private record DiffLineVm(string CssClass, string Prefix, string Content);

    private static List<DiffLineVm> ParsePatch(string patch)
    {
        if (string.IsNullOrEmpty(patch)) return new();

        var result = new List<DiffLineVm>();
        foreach (var raw in patch.Split('\n'))
        {
            if (raw.StartsWith("@@", StringComparison.Ordinal))
                result.Add(new("diff-line diff-hunk", "@@", raw.Length > 2 ? raw[2..] : ""));
            else if (raw.StartsWith('+'))
                result.Add(new("diff-line diff-add",  "+",  raw.Length > 1 ? raw[1..] : ""));
            else if (raw.StartsWith('-'))
                result.Add(new("diff-line diff-del",  "−",  raw.Length > 1 ? raw[1..] : ""));
            else
                result.Add(new("diff-line diff-ctx",  " ",  raw.Length > 1 ? raw[1..] : raw));
        }
        return result;
    }

    // ----------------------------------------------------------------
    // Status badge
    // ----------------------------------------------------------------

    private string GetStatusBadgeClass() => Diff.Status switch
    {
        DiffStatus.Added    => "badge-status badge-add",
        DiffStatus.Deleted  => "badge-status badge-del",
        DiffStatus.Renamed  => "badge-status badge-rename",
        DiffStatus.Copied   => "badge-status badge-rename",
        DiffStatus.Binary   => "badge-status badge-bin",
        _                   => "badge-status badge-mod"
    };
}
