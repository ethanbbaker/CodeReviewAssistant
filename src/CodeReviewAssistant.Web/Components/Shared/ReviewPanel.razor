@using CodeReviewAssistant.Core.Interfaces
@using CodeReviewAssistant.Core.Models
@using Markdig
@inject ICodeReviewService ReviewService

<div class="review-panel">

    @if (_status == ReviewStatus.Idle)
    {
        <!-- Start review CTA -->
        <div class="review-cta">
            <div class="review-cta-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z" />
                </svg>
            </div>
            <div class="review-cta-body">
                <h3 class="review-cta-title">AI Code Review</h3>
                <p class="review-cta-desc">
                    Let Claude analyse the diff for bugs, security issues, and improvement opportunities.
                </p>
                <button class="btn-start-review" @onclick="StartReview" type="button">
                    Start Review
                    <svg viewBox="0 0 16 16" fill="currentColor" width="14" height="14">
                        <path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0zM4.5 7.5a.5.5 0 0 0 0 1h5.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3a.5.5 0 0 0 0-.708l-3-3a.5.5 0 1 0-.708.708L10.293 7.5H4.5z"/>
                    </svg>
                </button>
            </div>
        </div>
    }
    else if (_status == ReviewStatus.Running || _status == ReviewStatus.Complete)
    {
        <!-- Header bar -->
        <div class="review-header">
            <div class="review-header-left">
                <svg class="review-header-icon @(_status == ReviewStatus.Running ? "review-icon-spin" : "")"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
                </svg>
                @if (_status == ReviewStatus.Running)
                {
                    <span class="review-status-text">
                        @if (_totalChunks > 1)
                        {
                            <span>Analysing chunk @(_currentChunk + 1) of @_totalChunks…</span>
                        }
                        else
                        {
                            <span>Analysing diff…</span>
                        }
                    </span>
                }
                else
                {
                    <span class="review-status-text review-status-done">Review complete</span>
                }
            </div>
            <div class="review-header-right">
                @if (_status == ReviewStatus.Running)
                {
                    <button class="btn-cancel-review" @onclick="CancelReview" type="button" title="Cancel review">
                        <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                            <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/>
                        </svg>
                        Cancel
                    </button>
                }
                else
                {
                    <button class="btn-rerun-review" @onclick="StartReview" type="button" title="Re-run review">
                        <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                            <path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z"/>
                            <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z"/>
                        </svg>
                        Re-run
                    </button>
                }
            </div>
        </div>

        <!-- Streaming progress bar -->
        @if (_status == ReviewStatus.Running)
        {
            <div class="review-progress-bar">
                <div class="review-progress-fill review-progress-animated"></div>
            </div>
        }

        <!-- Rendered markdown output -->
        <div class="review-body @(_status == ReviewStatus.Running ? "review-body-streaming" : "")">
            @if (_renderedHtml is not null)
            {
                @((MarkupString)_renderedHtml)
            }
            else if (_status == ReviewStatus.Running)
            {
                <div class="review-skeleton">
                    <div class="skeleton-line skeleton-line-lg"></div>
                    <div class="skeleton-line skeleton-line-md"></div>
                    <div class="skeleton-line skeleton-line-sm"></div>
                </div>
            }
        </div>
    }
    else if (_status == ReviewStatus.Cancelled)
    {
        <div class="review-cancelled">
            <svg viewBox="0 0 16 16" fill="currentColor" width="16" height="16">
                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/>
            </svg>
            <span>Review cancelled.</span>
            <button class="btn-link" @onclick="StartReview" type="button">Start again</button>
        </div>
    }
    else if (_status == ReviewStatus.Error)
    {
        <div class="review-error">
            <div class="review-error-icon">
                <svg viewBox="0 0 16 16" fill="currentColor">
                    <path d="M8 1a7 7 0 100 14A7 7 0 008 1zm-.75 3.75a.75.75 0 011.5 0v4a.75.75 0 01-1.5 0v-4zm.75 8a1 1 0 110-2 1 1 0 010 2z"/>
                </svg>
            </div>
            <div>
                <p class="review-error-msg">Review failed</p>
                @if (_errorMessage is not null)
                {
                    <p class="review-error-detail">@_errorMessage</p>
                }
                <button class="btn-retry" @onclick="StartReview" type="button">Try again</button>
            </div>
        </div>
    }

</div>

@code {
    [Parameter, EditorRequired] public PullRequestContext Context { get; set; } = null!;
    [Parameter]                 public ReviewOptions      Options { get; set; } = ReviewOptions.Default;

    private enum ReviewStatus { Idle, Running, Complete, Cancelled, Error }

    private ReviewStatus            _status        = ReviewStatus.Idle;
    private string                  _accumulatedMd = string.Empty;
    private string?                 _renderedHtml;
    private string?                 _errorMessage;
    private int                     _currentChunk;
    private int                     _totalChunks   = 1;
    private CancellationTokenSource? _cts;

    // ── Markdig pipeline (configured once per component instance) ────────────
    private static readonly MarkdownPipeline _mdPipeline =
        new MarkdownPipelineBuilder()
            .UseAdvancedExtensions()
            .Build();

    // ── Actions ───────────────────────────────────────────────────────────────

    private async Task StartReview()
    {
        // Reset state for a fresh run.
        _cts?.Cancel();
        _cts           = new CancellationTokenSource();
        _accumulatedMd = string.Empty;
        _renderedHtml  = null;
        _errorMessage  = null;
        _currentChunk  = 0;
        _totalChunks   = 1;
        _status        = ReviewStatus.Running;
        StateHasChanged();

        try
        {
            await foreach (var chunk in ReviewService.StreamReviewAsync(
                               Context, Options, _cts.Token))
            {
                if (chunk.IsProgress)
                {
                    // Update progress indicator — no text to append.
                    _currentChunk = chunk.ChunkIndex;
                    _totalChunks  = chunk.TotalChunks;
                }
                else
                {
                    _accumulatedMd += chunk.Text;
                    _renderedHtml   = Markdown.ToHtml(_accumulatedMd, _mdPipeline);
                }

                StateHasChanged();
            }

            _status = ReviewStatus.Complete;
        }
        catch (OperationCanceledException)
        {
            _status = ReviewStatus.Cancelled;
        }
        catch (Exception ex)
        {
            _status       = ReviewStatus.Error;
            _errorMessage = ex.Message is { Length: < 300 } m ? m : "An unexpected error occurred.";
        }
        finally
        {
            _cts?.Dispose();
            _cts = null;
            StateHasChanged();
        }
    }

    private void CancelReview()
    {
        _cts?.Cancel();
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
