@inject IReviewStateService ReviewState

<div class="diff-viewer">

    <!-- PR header -->
    <div class="pr-header">
        <div class="pr-header-main">
            <div class="pr-title-row">
                <h1 class="pr-title">@Context.Title</h1>
                <a class="pr-gh-link"
                   href="@Reference.ToString()"
                   target="_blank" rel="noopener noreferrer"
                   title="Open on GitHub">
                    <svg viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
                    </svg>
                    @Reference.Owner/@Reference.Repo #@Reference.PullRequestNumber
                </a>
            </div>

            <div class="pr-meta-row">
                <span class="pr-branch">
                    <span class="branch-chip">@Context.BaseBranch</span>
                    <svg viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <path fill-rule="evenodd" d="M1 8a.5.5 0 01.5-.5h11.793l-3.147-3.146a.5.5 0 01.708-.708l4 4a.5.5 0 010 .708l-4 4a.5.5 0 01-.708-.708L13.293 8.5H1.5A.5.5 0 011 8z"/>
                    </svg>
                    <span class="branch-chip head">@Context.HeadBranch</span>
                </span>

                <span class="pr-stat-pill add">+@Context.TotalAdditions</span>
                <span class="pr-stat-pill del">-@Context.TotalDeletions</span>
                <span class="pr-stat-pill neutral">
                    @Context.Files.Count file@(Context.Files.Count == 1 ? "" : "s")
                </span>
                @if (Context.TruncatedFileCount > 0)
                {
                    <span class="pr-stat-pill warn" title="Some large diffs were truncated">
                        @Context.TruncatedFileCount truncated
                    </span>
                }
                @if (Context.BinaryFileCount > 0)
                {
                    <span class="pr-stat-pill neutral">
                        @Context.BinaryFileCount binary
                    </span>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(Context.Description))
            {
                <details class="pr-description">
                    <summary>Description</summary>
                    <p>@Context.Description</p>
                </details>
            }
        </div>
    </div>

    <!-- File diffs -->
    <div class="diff-list">
        @for (int i = 0; i < Context.Files.Count; i++)
        {
            <FileDiffCard Diff="Context.Files[i]" Index="i" />
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public PullRequestContext  Context   { get; set; } = null!;
    [Parameter, EditorRequired] public GitHubPrReference  Reference { get; set; } = null!;
}
