@inject IReviewStateService ReviewState
@inject IReviewCacheService ReviewCache
@inject NavigationManager   Nav
@inject IJSRuntime          JS
@implements IDisposable

<!-- Brand row -->
<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid align-items-center gap-2">
        <img src="robot-logo.svg" alt="CodeReviewAI logo" class="brand-logo" />
        <a class="navbar-brand" href="/">CodeReview<span class="brand-accent">AI</span></a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable">

    <!-- ── Tab strip ───────────────────────────────────────────────── -->
    <div class="tab-strip">

        <!-- Search / home tab -->
        <button class="tab-item @(ReviewState.ActiveIndex == null ? "tab-active" : "")"
                @onclick="GoToSearch"
                title="Search for a pull request">
            <svg class="tab-icon" viewBox="0 0 16 16" fill="currentColor">
                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.099zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
            </svg>
            <span class="tab-label">Search</span>
        </button>

        <!-- One tab per open PR session -->
        @for (int i = 0; i < ReviewState.Sessions.Count; i++)
        {
            var idx     = i;
            var session = ReviewState.Sessions[i];
            <button class="tab-item @(ReviewState.ActiveIndex == idx ? "tab-active" : "")"
                    @onclick="() => ReviewState.SetActiveIndex(idx)"
                    title="@session.Context.Title">
                <svg class="tab-icon" viewBox="0 0 16 16" fill="currentColor">
                    <path fill-rule="evenodd" d="M5 3.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0zm0 2.122a2.25 2.25 0 1 0-1.5 0v.878A2.25 2.25 0 0 0 5.75 8.5h4.5a.75.75 0 0 1 .75.75v1.372a2.25 2.25 0 1 0 1.5 0V9.25a2.25 2.25 0 0 0-2.25-2.25h-4.5A.75.75 0 0 1 5 6.25V5.372zm8.25 6.128a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0z"/>
                </svg>
                <span class="tab-pr-label" title="@session.Context.Title">@TruncateTitle(session.Context.Title)</span>
                <span class="tab-close"
                      @onclick:stopPropagation
                      @onclick="() => ReviewState.RemoveSession(idx)"
                      title="Close">
                    <svg viewBox="0 0 16 16" fill="currentColor" width="10" height="10">
                        <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/>
                    </svg>
                </span>
            </button>
        }
    </div>

    <!-- ── Persistent nav links ──────────────────────────────────────── -->
    <div class="sidebar-nav-links px-3 pt-2 pb-1">
        <a class="sidebar-nav-link @(Nav.Uri.EndsWith("/history", StringComparison.OrdinalIgnoreCase) ? "sidebar-nav-link-active" : "")"
           href="/history">
            <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                <path d="M8 3.5a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9zM2.5 8a5.5 5.5 0 1 1 11 0 5.5 5.5 0 0 1-11 0z"/>
                <path d="M8 5a.5.5 0 0 1 .5.5v2.293l1.646 1.647a.5.5 0 0 1-.707.707l-1.793-1.793A.5.5 0 0 1 7.5 8V5.5A.5.5 0 0 1 8 5z"/>
            </svg>
            Review History
        </a>
    </div>
    <hr class="sidebar-divider" style="margin: 0.25rem 0;" />

    <!-- ── Active PR content ─────────────────────────────────────────── -->
    @if (ReviewState.ActiveIndex.HasValue && ReviewState.Context is { } ctx && ReviewState.Reference is { } rf)
    {
        <!-- PR meta -->
        <div class="pr-meta px-3 pt-2 pb-2">
            <a class="pr-meta-link"
               href="@rf.ToString()"
               target="_blank" rel="noopener noreferrer"
               title="Open on GitHub">
                PR&nbsp;#@rf.PullRequestNumber
                <svg style="width:10px;height:10px;vertical-align:-1px;margin-left:2px;opacity:.7;" viewBox="0 0 16 16" fill="currentColor">
                    <path fill-rule="evenodd" d="M8.636 3.5a.5.5 0 0 0-.5-.5H1.5A1.5 1.5 0 0 0 0 4.5v10A1.5 1.5 0 0 0 1.5 16h10a1.5 1.5 0 0 0 1.5-1.5V7.864a.5.5 0 0 0-1 0V14.5a.5.5 0 0 1-.5.5h-10a.5.5 0 0 1-.5-.5v-10a.5.5 0 0 1 .5-.5h6.636a.5.5 0 0 0 .5-.5z"/>
                    <path fill-rule="evenodd" d="M16 .5a.5.5 0 0 0-.5-.5h-5a.5.5 0 0 0 0 1h3.793L6.146 9.146a.5.5 0 1 0 .708.708L15 1.707V5.5a.5.5 0 0 0 1 0v-5z"/>
                </svg>
            </a>
            <p class="pr-meta-title" title="@ctx.Title">@ctx.Title</p>
            <div class="d-flex align-items-center gap-1 flex-wrap mt-1">
                <span class="branch-badge" title="Base branch">@ctx.BaseBranch</span>
                <svg style="width:10px;height:10px;opacity:.45;flex-shrink:0;" viewBox="0 0 16 16" fill="currentColor">
                    <path fill-rule="evenodd" d="M1 8a.5.5 0 01.5-.5h11.793l-3.147-3.146a.5.5 0 01.708-.708l4 4a.5.5 0 010 .708l-4 4a.5.5 0 01-.708-.708L13.293 8.5H1.5A.5.5 0 011 8z"/>
                </svg>
                <span class="branch-badge branch-badge-head" title="Head branch">@ctx.HeadBranch</span>
            </div>
        </div>

        <!-- Stats bar -->
        <div class="stats-bar px-3 pb-2">
            <span class="stat-add">+@ctx.TotalAdditions</span>
            <span class="stat-del">-@ctx.TotalDeletions</span>
            <span class="stat-files">@ctx.Files.Count file@(ctx.Files.Count == 1 ? "" : "s")</span>
        </div>

        <hr class="sidebar-divider" />

        <!-- File list -->
        <nav class="file-nav px-2 pb-3">
            <!-- Review link pinned at top -->
            @{
                var reviewState = ReviewCache.GetOrCreate(rf);
            }
            @if (reviewState.HasContent || reviewState.Status == ReviewRunStatus.Running)
            {
                <a class="file-item sidebar-review-link" href="#review-panel" title="Jump to AI review">
                    <svg class="@(reviewState.Status == ReviewRunStatus.Running ? "fj-review-spin" : "")"
                         viewBox="0 0 16 16" fill="currentColor" width="11" height="11" style="flex-shrink:0;">
                        <path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872l-.1-.34z"/>
                    </svg>
                    <span class="file-name">AI Review</span>
                    @if (reviewState.Status == ReviewRunStatus.Running)
                    {
                        <span class="badge-binary" style="color:var(--cra-accent-light);border-color:rgba(124,58,237,.4);">live</span>
                    }
                    else if (reviewState.Status == ReviewRunStatus.Complete)
                    {
                        <span class="badge-binary" style="color:var(--cra-success);border-color:rgba(52,211,153,.35);">done</span>
                    }
                </a>
                <hr class="sidebar-divider" style="margin:0.25rem 0;" />
            }

            @for (int i = 0; i < ctx.Files.Count; i++)
            {
                var file   = ctx.Files[i];
                var anchor = $"file-{i}";
                <a class="file-item" href="#@anchor"
                   @onclick:preventDefault
                   @onclick="() => ScrollToFile(anchor)"
                   title="@file.FileName">
                    <span class="@GetStatusDot(file.Status)" aria-hidden="true"></span>
                    <span class="file-name">@GetShortName(file.FileName)</span>
                    @if (!file.IsBinary)
                    {
                        <span class="file-stats">
                            <span class="stat-add-sm">+@file.Additions</span>
                            <span class="stat-del-sm">-@file.Deletions</span>
                        </span>
                    }
                    else
                    {
                        <span class="badge-binary">bin</span>
                    }
                </a>
            }
        </nav>
    }
    else
    {
        <!-- Search tab hint -->
        <div class="search-hint px-3 pt-3">
            <p class="search-hint-text">
                Enter a GitHub PR URL in the search field to load a pull request.
                Each fetched PR will appear as a tab here.
            </p>
        </div>
    }

</div>

@code {
    protected override void OnInitialized()
    {
        ReviewState.OnChange += StateHasChanged;
        ReviewCache.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        ReviewState.OnChange -= StateHasChanged;
        ReviewCache.OnChange -= StateHasChanged;
    }

    private void GoToSearch()
    {
        ReviewState.SetActiveIndex(null);
        // If we're not already on the home page, navigate there.
        if (!Nav.Uri.TrimEnd('/').Equals(Nav.BaseUri.TrimEnd('/'), StringComparison.OrdinalIgnoreCase))
            Nav.NavigateTo("/");
    }

    private void ScrollToFile(string id) =>
        JS.InvokeVoidAsync("craScrollToFile", id);

    private static string GetStatusDot(DiffStatus status) => status switch
    {
        DiffStatus.Added   => "status-dot dot-add",
        DiffStatus.Deleted => "status-dot dot-del",
        DiffStatus.Renamed => "status-dot dot-rename",
        DiffStatus.Copied  => "status-dot dot-rename",
        DiffStatus.Binary  => "status-dot dot-binary",
        _                  => "status-dot dot-mod"
    };

    /// <summary>Truncates a PR title to fit the narrow sidebar tab without changing its size.</summary>
    private static string TruncateTitle(string title) =>
        title.Length <= 22 ? title : title[..19] + "…";

    private static string GetShortName(string path)
    {
        var slash = path.LastIndexOf('/');
        return slash >= 0 ? path[(slash + 1)..] : path;
    }
}
